{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/leads-public",
      "destination": "/api/leads-public.ts"
    },
    {
      "source": "/api/meta-lead-webhook",
      "destination": "/api/meta-lead-webhook.ts"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
