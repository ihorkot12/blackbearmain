{
  "version": 2,
  "crons": [
    {
      "path": "/api/telegram/dispatch",
      "schedule": "0 8 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'none'; base-uri 'self'; object-src 'none'"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/parent/telegram-link",
      "destination": "/api/mono-parent-status.ts?mode=telegram-link"
    },
    {
      "source": "/api/parent/social-links",
      "destination": "/api/mono-parent-status.ts?mode=parent-social-links"
    },
    {
      "source": "/api/telegram/parent-webhook",
      "destination": "/api/mono-parent-status.ts?mode=telegram-webhook"
    },
    {
      "source": "/api/telegram/dispatch",
      "destination": "/api/mono-parent-status.ts?mode=telegram-dispatch"
    },
    {
      "source": "/api/leads-public",
      "destination": "/api/leads-public.ts"
    },
    {
      "source": "/api/meta-lead-webhook",
      "destination": "/api/meta-lead-webhook.ts"
    },
    {
      "source": "/api/social/ig/connect-url",
      "destination": "/api/instagram-auth-url.ts"
    },
    {
      "source": "/api/social/ig/status",
      "destination": "/api/instagram-admin.ts?mode=status"
    },
    {
      "source": "/api/social/ig/sync",
      "destination": "/api/instagram-admin.ts?mode=sync"
    },
    {
      "source": "/api/social/ig/accounts",
      "destination": "/api/instagram-admin.ts?mode=accounts"
    },
    {
      "source": "/api/social/ig/select-account",
      "destination": "/api/instagram-admin.ts?mode=select-account"
    },
    {
      "source": "/api/social/ig/manual-connect",
      "destination": "/api/instagram-manual-connect.ts"
    },
    {
      "source": "/api/auth/instagram/url",
      "destination": "/api/instagram-auth-url.ts"
    },
    {
      "source": "/api/auth/instagram/callback",
      "destination": "/api/instagram-callback.ts"
    },
    {
      "source": "/api/instagram/status",
      "destination": "/api/instagram-admin.ts?mode=status"
    },
    {
      "source": "/api/instagram/sync",
      "destination": "/api/instagram-admin.ts?mode=sync"
    },
    {
      "source": "/api/instagram/accounts",
      "destination": "/api/instagram-admin.ts?mode=accounts"
    },
    {
      "source": "/api/instagram/select-account",
      "destination": "/api/instagram-admin.ts?mode=select-account"
    },
    {
      "source": "/api/instagram/credentials",
      "destination": "/api/instagram-credentials.ts"
    },
    {
      "source": "/api/instagram/manual-connect",
      "destination": "/api/instagram-manual-connect.ts"
    },
    {
      "source": "/api/parent/payments/monobank-config",
      "destination": "/api/mono-parent-config.ts"
    },
    {
      "source": "/api/parent/payments/monobank-invoice",
      "destination": "/api/mono-parent-invoice.ts"
    },
    {
      "source": "/api/parent/payments/monobank-status",
      "destination": "/api/mono-parent-status.ts"
    },
    {
      "source": "/api/monobank/webhook",
      "destination": "/api/monobank-webhook.ts"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
